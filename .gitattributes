# Treat all binary assets as binary — prevents CRLF/UTF-8 corruption
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.svg text eol=lf
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary

# Text files — enforce LF
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md  text eol=lf
